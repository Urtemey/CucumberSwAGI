# LM Studio (OpenAI-compatible API)
LLM_BASE_URL=http://192.168.0.120:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=google/gemma-4-26b-a4b

# Эмбеддинги в LM Studio. Имя зависит от того, какая модель загружена;
# для nomic-embed-text размерность 768.
EMBED_BASE_URL=http://192.168.0.120:1234/v1
EMBED_API_KEY=lm-studio
EMBED_MODEL=text-embedding-nomic-embed-text-v1.5
EMBED_DIM=768

# Qdrant (локальный режим — путь к директории, либо :memory:)
RAG_QDRANT_PATH=./task10/qdrant_data
RAG_COLLECTION=knowledge_base

# task9 — где лежит файл памяти MCP-сервера
MEMORY_STORAGE_PATH=./task9/memory_data.json
